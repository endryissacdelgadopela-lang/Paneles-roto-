<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fantamista YT - Paneles Oficiales</title>
    <style>
        body {
            background-color: #0d0d0d;
            color: #ffffff;
            font-family: 'Arial Black', Gadget, sans-serif;
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
        }
        
        header {
            text-align: center;
            margin-bottom: 25px;
        }

        h1 {
            color: #ffffff;
            font-size: 32px;
            margin: 0;
            text-shadow: 0 0 10px #ff3c00;
            text-transform: uppercase;
        }

        /* --- SECCIÓN DE STATUS GLOBAL --- */
        .status-container {
            background: linear-gradient(135deg, #141414 0%, #1a1a1a 100%);
            border: 1px solid #333;
            border-radius: 12px;
            padding: 15px 25px;
            margin-top: 15px;
            display: flex;
            gap: 20px;
            justify-content: center;
            align-items: center;
            flex-wrap: wrap;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.5);
        }

        .status-item {
            font-family: 'Segoe UI', sans-serif;
            font-size: 13px;
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 8px;
            text-transform: uppercase;
        }

        .dot {
            height: 10px;
            width: 10px;
            border-radius: 50%;
            display: inline-block;
        }

        .dot-online {
            background-color: #00ff66;
            box-shadow: 0 0 8px #00ff66;
        }

        .container {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 25px;
            max-width: 1200px;
            width: 100%;
            margin-top: 20px;
        }

        .panel-card {
            background: linear-gradient(135deg, #141414 0%, #1f1f1f 100%);
            border: 2px solid #333;
            border-radius: 15px;
            padding: 25px;
            width: 260px;
            text-align: center;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        /* Estilos de colores por sección */
        .ff-style {
            border-color: #ff3c00;
            box-shadow: 0 0 15px rgba(255, 60, 0, 0.2);
        }
        .ff-style h2 { color: #ff4500; }

        .rb-style {
            border-color: #00c6ff;
            box-shadow: 0 0 15px rgba(0, 198, 255, 0.2);
        }
        .rb-style h2 { color: #00c6ff; }

        .deluxe-style {
            border-color: #ff0055;
            box-shadow: 0 0 15px rgba(255, 0, 85, 0.3);
        }
        .deluxe-style h2 { color: #ff3377; }

        /* Estilo para CubanMod V8 Premium */
        .cuban-style {
            border-color: #ffaa00;
            box-shadow: 0 0 15px rgba(255, 170, 0, 0.3);
        }
        .cuban-style h2 { color: #ffaa00; }

        h2 {
            font-size: 19px;
            margin-top: 0;
            text-transform: uppercase;
        }

        p {
            font-family: 'Segoe UI', sans-serif;
            color: #aaaaaa;
            font-size: 13px;
            line-height: 1.5;
            margin-bottom: 15px;
        }

        .stock-badge {
            font-family: 'Segoe UI', sans-serif;
            background-color: rgba(255, 255, 255, 0.1);
            color: #ffffff;
            padding: 5px 12px;
            font-size: 11px;
            font-weight: bold;
            border-radius: 8px;
            display: inline-block;
            margin-bottom: 20px;
            border: 1px dashed #666;
        }

        .ff-style .stock-badge { color: #ffaa00; border-color: #ff4500; }
        .rb-style .stock-badge { color: #00e5ff; border-color: #00c6ff; }
        .deluxe-style .stock-badge { color: #ff3377; border-color: #ff0055; }
        .cuban-style .stock-badge { color: #ffaa00; border-color: #ffaa00; }

        .btn-adquirir {
            background-color: #25d366;
            color: white;
            border: none;
            padding: 12px 20px;
            font-size: 14px;
            font-weight: bold;
            border-radius: 25px;
            cursor: pointer;
            text-transform: uppercase;
            width: 100%;
            transition: 0.2s ease;
        }
        .btn-adquirir:hover { transform: scale(1.05); background-color: #20ba5a; }
    </style>
</head>
<body>

    <header>
        <h1>FANTAMISTA YT</h1>
        
        <div class="status-container">
            <div class="status-item">
                <span class="dot dot-online"></span>
                Servidor: Online
            </div>
            <div class="status-item" style="color: #ffcc00;">
                <span class="dot dot-online" style="background-color: #ffcc00; box-shadow: 0 0 8px #ffcc00;"></span>
                Paneles: Disponibles
            </div>
            <div class="status-item">
                <span class="dot dot-online"></span>
                Soporte: Activo
            </div>
        </div>
    </header>

    <div class="container">
        
        <!-- PANEL 1: GRAN MAESTRO -->
        <div class="panel-card ff-style">
            <div>
                <h2>PANEL GRAN MAESTRO</h2>
                <p>El panel definitivo para que tu cuenta suba al rango máximo en Free Fire de forma segura y rápida.</p>
                <p><strong>A CAMBIO DE:</strong><br>Una cuenta de Free Fire.</p>
            </div>
            <div>
                <div class="stock-badge">⚠️ CANTIDAD LIMITADA: 1000/1000</div>
                <button class="btn-adquirir" onclick="solicitarPanel('Gran Maestro', 'una cuenta de Free Fire')">
                    Pedir Panel
                </button>
            </div>
        </div>

        <!-- PANEL 2: PROXY VIP -->
        <div class="panel-card rb-style">
            <div>
                <h2>PANEL PROXY VIP</h2>
                <p>Panel Proxy VIP exclusivo e indetectable para potenciar tus juegos y cuentas secundarias en Roblox.</p>
                <p><strong>A CAMBIO DE:</strong><br>Una cuenta de Roblox.</p>
            </div>
            <div>
                <div class="stock-badge">⚠️ CANTIDAD LIMITADA: 1000/1000</div>
                <button class="btn-adquirir" onclick="solicitarPanel('Proxy VIP', 'una cuenta de Roblox')">
                    Pedir Panel
                </button>
            </div>
        </div>

        <!-- PANEL 3: PROXY N DELUXE -->
        <div class="panel-card deluxe-style">
            <div>
                <h2>PROXY N DELUXE 🛒</h2>
                <p>Compra tu Key oficial para el panel premium Proxy N DELUXE 100% funcional y seguro.</p>
                <p><strong>A CAMBIO DE:</strong><br>❤️ Una cuenta de Roblox (SIN ROOT).</p>
            </div>
            <div>
                <div class="stock-badge">⚠️ KEYS DISPONIBLES: 1000/1000</div>
                <button class="btn-adquirir" onclick="comprarKeyDeluxe()">
                    Comprar Key 🛒
                </button>
            </div>
        </div>

        <!-- PANEL 4: CUBANMOD V8 PREMIUM (CORREGIDO) -->
        <div class="panel-card cuban-style">
            <div>
                <h2>CUBANMOD V8 PANEL</h2>
                <p>Consigue el potente menú exclusivo de CubanMod V8 completamente actualizado y con soporte estable.</p>
                <p><strong>A CAMBIO DE:</strong><br>Una cuenta vinculada.</p>
            </div>
            <div>
                <div class="stock-badge">⚠️ PANELES: 1000/1000</div>
                <button class="btn-adquirir" onclick="solicitarCubanMod()">
                    Pedir Panel
                </button>
            </div>
        </div>

    </div>

    <script>
        function solicitarPanel(nombrePanel, cambio) {
            const telefono = "18294883400"; 
            const mensaje = `Hola bro buenas, vengo de tu página web. Me interesa mucho el *Panel ${nombrePanel}*. Estoy dispuesto a darte ${cambio} a cambio del trato. ¿Cómo hacemos?`;
            const mensajeCodificado = encodeURIComponent(mensaje);
            window.open(`https://api.whatsapp.com/send?phone=${telefono}&text=${mensajeCodificado}`, '_blank');
        }

        function comprarKeyDeluxe() {
            const telefono = "18294883400";
            const mensajeKey = "Hola Fantamista YT, vengo de tu web. Quiero realizar la Compra 🛒 de la Key para el *PROXY N DELUXE SIN ROOT*. Te daré una cuenta de Roblox ❤️ a cambio. ¿Cómo hacemos el trato?";
            const mensajeCodificado = encodeURIComponent(mensajeKey);
            window.open(`https://api.whatsapp.com/send?phone=${telefono}&text=${mensajeCodificado}`, '_blank');
        }

        function solicitarCubanMod() {
            const telefono = "18294883400";
            // Mensaje de trato directo por cuenta para el CubanMod V8
            const mensajeCuban = "Hola bro buenas! Vengo de tu web. Me interesa el panel de *CUBANMOD V8*. Quisiera hacer el trato por la cuenta. ¿Cómo hacemos?";
            const mensajeCodificado = encodeURIComponent(mensajeCuban);
            window.open(`https://api.whatsapp.com/send?phone=${telefono}&text=${mensajeCodificado}`, '_blank');
        }
    </script>

</body>
</html>
